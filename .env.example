# Copy to .env and fill in. Never commit .env.

# ---- LLM provider ----
# Set provider in configs/default.yaml: gemini | qwen | stub
GEMINI_API_KEY=
# OPENAI_API_KEY=

# Qwen2.5-VL runs locally - no API key needed.
# Install with: pip install '.[local]'
# Then set llm.provider: qwen in configs/default.yaml.

# ---- Optional overrides for configs/default.yaml ----
# RETAIL_MONITOR_CONFIG=configs/default.yaml
# RETAIL_MONITOR_LOG_LEVEL=INFO
# RETAIL_MONITOR_DEVICE=auto
# RETAIL_MONITOR_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ---- Example RTSP URLs (do not commit real credentials) ----
# RTSP_URL=rtsp://user:pass@192.168.1.50:554/Streaming/Channels/101
